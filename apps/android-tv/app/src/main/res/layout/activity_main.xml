<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:keepScreenOn="true" />

    <FrameLayout
        android:id="@+id/status_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <View
            android:id="@+id/status_backdrop"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/tv_background" />

        <View
            android:id="@+id/status_scrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/status_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/status_card_background"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="28dp">

            <ImageView
                android:id="@+id/status_logo"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_clawtv_brand" />

            <TextView
                android:id="@+id/status_brand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.72"
                android:letterSpacing="0.12"
                android:text="@string/app_name"
                android:textAllCaps="true"
                android:textColor="@color/clawtv_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/status_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/status_loading_title"
                android:textColor="@color/clawtv_text_primary"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/status_message"
                android:layout_width="420dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/status_loading_message"
                android:textColor="@color/clawtv_text_secondary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/status_now_playing"
                android:layout_width="420dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:textColor="@color/clawtv_text_secondary"
                android:textSize="16sp" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/voice_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#A6000000"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="48dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/status_card_background"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="28dp">

            <ImageView
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_clawtv_brand" />

            <TextView
                android:id="@+id/voice_brand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.72"
                android:letterSpacing="0.12"
                android:text="@string/voice_brand_default"
                android:textAllCaps="true"
                android:textColor="@color/clawtv_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/voice_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:includeFontPadding="false"
                android:text="@string/voice_title_idle_default"
                android:textColor="@color/clawtv_text_primary"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/voice_message"
                android:layout_width="420dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/voice_message_idle_default"
                android:textColor="@color/clawtv_text_secondary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/voice_transcript"
                android:layout_width="420dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:textColor="@color/clawtv_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/voice_hint"
                android:layout_width="420dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="@string/voice_hint"
                android:textColor="@color/clawtv_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
