<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:keepScreenOn="true" />

    <LinearLayout
        android:id="@+id/status_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/tv_background"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="48dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/status_card_background"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/status_brand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.72"
                android:letterSpacing="0.12"
                android:text="@string/app_name"
                android:textAllCaps="true"
                android:textColor="@color/clawtv_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/status_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/status_loading_title"
                android:textColor="@color/clawtv_text_primary"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/status_message"
                android:layout_width="420dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/status_loading_message"
                android:textColor="@color/clawtv_text_secondary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/status_now_playing"
                android:layout_width="420dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:textColor="@color/clawtv_text_secondary"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
