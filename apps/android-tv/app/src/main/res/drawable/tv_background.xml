<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/clawtv_black" />
    <item>
        <bitmap
            android:antialias="true"
            android:filter="true"
            android:gravity="fill"
            android:src="@drawable/clawtv_brand_art" />
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#26000000" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:centerColor="#1A050505"
                android:endColor="#B3050505"
                android:startColor="#73050505" />
        </shape>
    </item>
</layer-list>
